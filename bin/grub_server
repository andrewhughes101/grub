#!/bin/sh

#
# This script requires tight hand-shaking with grub_client
# for parameter passing from the client to the server
#

server_root="$1"
repo="$2"
git_dir="$3"
build_command="$4"
server_name="$5"
has_unstaged_changes="$6"
local_user="$7"
branch="$8"

# Platform check to see if we're on z/OS
uname_output=$(uname -s 2>/dev/null)
if echo "$uname_output" | grep -qi "OS/390"; then
  zos="True"
else
  zos="False"
fi


# Use TMPDIR if set, otherwise fall back to /tmp
tmpdir="${TMPDIR:-/tmp}"
bld_out="${tmpdir}/grub.${local_user}_${server_name}_${repo}.out"
bld_err="${tmpdir}/grub.${local_user}_${server_name}_${repo}.err"

# Delete old log files to prevent displaying stale output from previous runs
# This is critical when patch application fails - we don't want to show
# old successful build output when the current build didn't actually run
rm "${bld_out}" 2>/dev/null || true
rm "${bld_err}" 2>/dev/null || true

# Setup z/OS tagging and auto conversion
if [ "${zos}" = "True" ]; then
  export _BPXK_AUTOCVT=ON
  export _CEE_RUNOPTS="$_CEE_RUNOPTS FILETAG(AUTOCVT,AUTOTAG)"
  export _TAG_REDIR_ERR=txt
  export _TAG_REDIR_IN=txt
  export _TAG_REDIR_OUT=txt

  # Make the log files up front so we can tag them
  touch "${bld_out}"
  touch "${bld_err}"

  chtag -b "${bld_out}" 2>/dev/null || true
  chtag -b "${bld_err}" 2>/dev/null || true
fi

# Echo paths back to client so it knows where to download from
echo "GRUB_OUT=${bld_out}"
echo "GRUB_ERR=${bld_err}"

#
# Add the git_dir to the PATH so that git and bash can be located
#

if [ -d "${git_dir}" ] ; then
  export PATH="${git_dir}:$PATH"
else
  echo "Unable to set up git PATH with ${git_dir}" >&2
  exit 4
fi

#
# We call a second script to do the 'real' work and
# redirect the stdout and stderr to files so the client
# can then download the output
#

# Change to repo directory and checkout the correct branch
cd "$server_root/$repo" || {
  echo "Error: Failed to change to directory $server_root/$repo" >&2
  exit 4
}

# Checkout the branch that was pushed
"$git_dir"/git checkout "$branch" >/dev/null 2>&1 || {
  echo "Error: Failed to checkout branch $branch" >&2
  exit 4
}

# Apply patch file if there were unstaged changes
if [ "$has_unstaged_changes" = "1" ]; then
  # Patch file is in /tmp (where client puts it)
  patch_file="/tmp/grub.${local_user}_${server_name}_${repo}.patch"

  if [ -f "$patch_file" ]; then
    # On z/OS with zos-working-tree-encoding, use 3-way merge to handle encoding differences
    # The patch is in ascii (from client), but working tree files may be in IBM-1047
    if [ "${zos}" = "True" ]; then
      # Tag patch as ascii for proper reading
      chtag -tc iso8859-1 "$patch_file" 2>/dev/null || true

      # Extract list of files from the patch before applying
      modified_files=$(grep -E '^\+\+\+ [bw]/' "$patch_file" | sed 's|^+++ [bw]/||' | sort -u)

      # Use 3-way merge which can handle the encoding mismatch
      "$git_dir"/git apply --3way --whitespace=nowarn "$patch_file" 2>&1
      patch_result=$?

      if [ $patch_result -eq 0 ]; then
        # After 3-way merge, files have correct content but may have wrong encoding tags
        # Fix the tags based on .gitattributes zos-working-tree-encoding
        echo "$modified_files" | while read -r file; do
          if [ -n "$file" ] && [ -f "$file" ]; then
            # Get the expected encoding from .gitattributes
            expected_encoding=$("$git_dir"/git check-attr zos-working-tree-encoding -- "$file" | cut -d: -f3 | tr -d ' ')

            # Re-tag the file with the correct encoding
            if [ "$expected_encoding" != "unspecified" ] && [ "$expected_encoding" != "unset" ]; then
              chtag -tc "$expected_encoding" "$file" 2>/dev/null || true
            fi
          fi
        done
      fi
    else
      # Non-z/OS: standard apply
      "$git_dir"/git apply --whitespace=nowarn "$patch_file" 2>&1
      patch_result=$?
    fi

    if [ $patch_result -ne 0 ]; then
      echo "Error: Patch application failed (exit code: $patch_result)" >&2
      echo "This may indicate conflicts between your local changes and the remote branch" >&2
      exit 4
    fi

    # Clean up patch file after applying
    rm -f "$patch_file"
  else
    echo "Warning: Expected patch file $patch_file not found" >&2
  fi
fi


# Execute build command with buffered streaming using named pipes

echo "Executing command '$build_command'"

# Create named pipes for stdout and stderr
pipe_out="${tmpdir}/grub_${server_name}_${repo}_out.pipe"
pipe_err="${tmpdir}/grub_${server_name}_${repo}_err.pipe"
mkfifo "$pipe_out" "$pipe_err"

# Start tee processes in background to read from pipes and write to files/terminal
tee "${bld_out}" < "$pipe_out" &
tee "${bld_err}" < "$pipe_err" >&2 &

# Run build command with output redirected to named pipes
bash -c "$build_command" >"$pipe_out" 2>"$pipe_err"
build_exit_code=$?

# Wait for tee processes to finish
wait

# Clean up named pipes
rm -f "$pipe_out" "$pipe_err"

# Exit with the build command's exit code
exit $build_exit_code
